#!/bin/sh
set -e

APP_DIR=/usr/lib/vhs-digitizer
DATA_DIR=/var/lib/vhs-digitizer
SERVICE_USER=vhs-digitizer

case "$1" in
    configure)
        # Create dedicated system user if it does not exist
        if ! id "$SERVICE_USER" >/dev/null 2>&1; then
            adduser \
                --system \
                --group \
                --no-create-home \
                --home "$DATA_DIR" \
                --shell /usr/sbin/nologin \
                --gecos "VHS Digitizer service account" \
                "$SERVICE_USER"
        fi

        # Create writable data directories
        mkdir -p "$DATA_DIR/recordings"
        chown -R "$SERVICE_USER:$SERVICE_USER" "$DATA_DIR"
        chmod 750 "$DATA_DIR"
        chmod 750 "$DATA_DIR/recordings"

        # Build virtualenv at its final location so paths are correct
        if [ ! -d "$APP_DIR/venv" ]; then
            python3 -m venv "$APP_DIR/venv"
        fi

        # Install pinned Python dependencies from the bundled requirements file
        "$APP_DIR/venv/bin/pip" install \
            --quiet \
            --no-cache-dir \
            -r "$APP_DIR/requirements.txt"

        # Install and enable the systemd service
        install -m 644 "$APP_DIR/vhs-digitizer.service" \
            /lib/systemd/system/vhs-digitizer.service
        systemctl daemon-reload
        systemctl enable vhs-digitizer.service
        systemctl start vhs-digitizer.service
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
